{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "react": ["vendor/node_modules/@types/react"],
      "react/jsx-runtime": ["vendor/node_modules/@types/react/jsx-runtime"],
      "react-dom/client": ["vendor/node_modules/@types/react-dom/client"]
    },
    "typeRoots": ["vendor/node_modules/@types"]
  },
  "include": ["src"]
}
